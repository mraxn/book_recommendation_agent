# Pinecone (key provided with the test assignment)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=books
PINECONE_NAMESPACE=books-v1
PINECONE_EMBED_MODEL=llama-text-embed-v2

# LLM provider
LLM_PROVIDER=ollama
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b

# Optional hosted providers. Their packages are loaded only when selected.
# OPENAI_API_KEY=your-openai-key-here
# OPENAI_MODEL=your-openai-model-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=your-anthropic-key-here
# ANTHROPIC_MODEL=your-anthropic-model-here
